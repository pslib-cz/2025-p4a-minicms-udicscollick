AUTH_SECRET="WgdB88mU08vkeJ3Z+vOGjZAGmTpZJPTQxhtU37xfMq6AnNi59Ux2Qr6pSzg="
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# For custom PostgreSQL deployments
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/minicms?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/minicms?schema=public"

